{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tunaFlow",
  "version": "0.1.0",
  "identifier": "com.tunaflow.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "tunaFlow",
        "width": 1200,
        "height": 800,
        "visible": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "externalBin": ["binaries/rawq"]
  }
}
